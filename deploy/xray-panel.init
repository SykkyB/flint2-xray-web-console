#!/bin/sh /etc/rc.common
# procd init for xray-panel on OpenWrt / GL.iNet Flint 2.

USE_PROCD=1
START=95
STOP=10

PROG=/usr/bin/xray-panel
CONF=/etc/xray-panel/panel.yaml

start_service() {
	[ -x "$PROG" ] || {
		echo "xray-panel: $PROG missing or not executable" >&2
		return 1
	}
	[ -f "$CONF" ] || {
		echo "xray-panel: $CONF missing" >&2
		return 1
	}

	procd_open_instance
	procd_set_param command "$PROG" -config "$CONF"
	procd_set_param respawn 3600 5 0
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_set_param file "$CONF"
	procd_close_instance
}

reload_service() {
	stop
	start
}
